  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Abs", "@", "spin"}], "==", "2"}], ",", " ", 
     RowBox[{"VRW", "=", 
