       RowBox[{"a", "/", 
        RowBox[{"r", "^", "2"}]}], "*", " ", 
       RowBox[{"(", " ", 
        RowBox[{
         RowBox[{"l", "*", 
          RowBox[{"(", 
           RowBox[{"l", "+", "1"}], ")"}]}], " ", "-", " ", 
         RowBox[{"6", 
