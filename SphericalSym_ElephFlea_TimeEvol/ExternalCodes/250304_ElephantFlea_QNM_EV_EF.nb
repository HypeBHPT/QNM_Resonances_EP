      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "nQNMLong"}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"PosBranch", "=", 
