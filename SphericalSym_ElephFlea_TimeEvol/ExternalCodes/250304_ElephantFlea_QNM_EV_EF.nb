Cell[CellGroupData[{

Cell["Filter discrete from continuous spectra", "Subsubsection",ExpressionUUID->"32cc177c-4f08-44d3-aac8-036912a62d7d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QNM$filter", "[", 
   RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"list", "=", 
      RowBox[{"{", "}"}]}], "}"}], ",", 
    RowBox[{
     RowBox[{"tab", "=", "y"}], ";", 
     RowBox[{"tab1", "=", "z"}], ";", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"tab", "[", 
                 RowBox[{"[", 
                  RowBox[{"-", "j"}], "]"}], "]"}], "-", 
                RowBox[{"tab1", "[", 
                 RowBox[{"[", 
                  RowBox[{"-", "i"}], "]"}], "]"}]}], ")"}], "/", 
              RowBox[{"tab", "[", 
               RowBox[{"[", 
                RowBox[{"-", "j"}], "]"}], "]"}]}], "]"}], "<", "x"}], "\n", 
           RowBox[{"(*", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"tab", "[", 
                    RowBox[{"[", 
                    RowBox[{"-", "j"}], "]"}], "]"}], "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "-", 
                   RowBox[{
                    RowBox[{"tab1", "[", 
                    RowBox[{"[", 
                    RowBox[{"-", "i"}], "]"}], "]"}], "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/", 
                 RowBox[{
                  RowBox[{"tab", "[", 
                   RowBox[{"[", 
                    RowBox[{"-", "j"}], "]"}], "]"}], "[", 
                  RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "<", "x"}], 
              "\[And]", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"tab", "[", 
                    RowBox[{"[", 
                    RowBox[{"-", "j"}], "]"}], "]"}], "[", 
                    RowBox[{"[", "2", "]"}], "]"}], "-", 
                   RowBox[{
                    RowBox[{"tab1", "[", 
                    RowBox[{"[", 
                    RowBox[{"-", "i"}], "]"}], "]"}], "[", 
                    RowBox[{"[", "2", "]"}], "]"}]}], ")"}], "/", 
                 RowBox[{
                  RowBox[{"tab", "[", 
                   RowBox[{"[", 
                    RowBox[{"-", "j"}], "]"}], "]"}], "[", 
                  RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "<", "x"}]}]}], 
            "*)"}], ",", 
           RowBox[{"AppendTo", "[", 
            RowBox[{"list", ",", 
             RowBox[{"tab1", "[", 
              RowBox[{"[", 
               RowBox[{"-", "i"}], "]"}], "]"}]}], "]"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "1", ",", 
           RowBox[{"Length", "[", "tab", "]"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", 
         RowBox[{"Length", "[", "tab1", "]"}]}], "}"}]}], "]"}], ";", 
     "list"}]}], "]"}]}]], "Code",
 CellLabel->
  "In[266]:=",ExpressionUUID->"27d1a5ab-8c99-4729-95dd-e22c38a80778"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"PosQNMLong", "=", 
   RowBox[{
    RowBox[{"Position", "[", 
     RowBox[{
      RowBox[{"EigenSol", "[", 
       RowBox[{"[", "1", "]"}], "]"}], ",", 
      RowBox[{"x_", "/;", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Im", "@", "x"}], "!=", "0"}], " ", "&&", " ", 
        RowBox[{
         RowBox[{"Re", "@", "x"}], " ", "<", " ", "0"}]}]}]}], "]"}], "//", 
    "Flatten"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"nQNMLong", "=", 
   RowBox[{"Length", "@", "PosQNMLong"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Omega]$QNMLong", "=", 
   RowBox[{"Table", "[", 
