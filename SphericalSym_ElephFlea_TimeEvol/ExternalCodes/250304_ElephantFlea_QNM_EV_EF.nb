       RowBox[{
        RowBox[{"Im", "@", "x"}], "==", "0"}]}]}], "]"}], "//", "Flatten"}]}],
   ";"}], "\n", 
 RowBox[{
  RowBox[{"nBranch", "=", 
   RowBox[{"Length", "@", "PosBranch"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Omega]$BranchCut", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"\[Omega]", "[", 
       RowBox[{"[", 
        RowBox[{"PosBranch", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "nBranch"}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"BranchCutData", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Re", "@", 
        RowBox[{"\[Omega]$BranchCut", "[", 
         RowBox[{"[", "iqnm", "]"}], "]"}]}], ",", 
       RowBox[{"Im", "@", 
        RowBox[{"\[Omega]$BranchCut", "[", 
         RowBox[{"[", "iqnm", "]"}], "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"iqnm", ",", "1", ",", "nBranch"}], "}"}]}], "]"}]}], 
  ";"}]}], "Code",
 CellLabel->
  "In[267]:=",ExpressionUUID->"d932a4cb-6ce7-496a-8fb9-c57e502df9a0"],

