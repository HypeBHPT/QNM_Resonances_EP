     RowBox[{"\[Omega]", "[", 
      RowBox[{"[", 
       RowBox[{"PosQNMLong", "[", 
        RowBox[{"[", "i", "]"}], "]"}], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "nQNMLong"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
