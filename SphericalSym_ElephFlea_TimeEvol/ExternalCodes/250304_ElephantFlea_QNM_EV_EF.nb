Cell[BoxData[{
 RowBox[{"DirName$InputData", "=", 
  RowBox[{"\"\<../input_data/eps_\>\"", "<>", 
   RowBox[{"ToString", "[", 
    RowBox[{
     RowBox[{"N", "[", "\[Epsilon]", "]"}], ",", "CForm"}], "]"}], "<>", 
   "\"\<_a0_Over_rh_\>\"", "<>", 
   RowBox[{"ToString", "[", 
    RowBox[{
     RowBox[{"N", "[", "ao", "]"}], ",", "CForm"}], "]"}]}]}], "\n", 
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"!", 
     RowBox[{"DirectoryQ", "[", "DirName$InputData", "]"}]}], ",", 
    RowBox[{"CreateDirectory", "[", "DirName$InputData", "]"}]}], "]"}], 
  "\n"}], "\n", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"iQNM", "=", "0"}], ",", " ", 
   RowBox[{"iQNM", "<", 
    RowBox[{"nQNM", "/", "2"}]}], ",", " ", 
   RowBox[{"iQNM", "++"}], ",", "\n", "\n", 
   RowBox[{
    RowBox[{"Nz", "=", "Nz$dom0"}], ";", "\n", "\n", 
    RowBox[{"fn", "=", 
     RowBox[{"DirName$InputData", "<>", "\"\</Cheb_QNM_dom0_N_\>\"", "<>", 
      RowBox[{"ToString", "[", "Nz", "]"}], "<>", "\"\<_n\>\"", "<>", 
      RowBox[{"ToString", "[", "iQNM", "]"}], "<>", "\"\<_l\>\"", "<>", 
      RowBox[{"ToString", "[", "l", "]"}], "<>", "\"\<_spin\>\"", "<>", 
      RowBox[{"ToString", "[", "spin", "]"}], "<>", "\"\<_Prec_\>\"", "<>", 
      RowBox[{"ToString", "[", 
       RowBox[{"N", "[", "Prec", "]"}], "]"}], "<>", "\"\<.dat\>\""}]}], ";", 
    "\n", 
    RowBox[{"NumericalData", "=", 
     RowBox[{"{", "\n", 
      RowBox[{
       RowBox[{"\"\<s\\t\>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Re", "[", 
          RowBox[{"s$n0", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"2", "*", "iQNM"}], "+", "1"}], "]"}], "]"}], "]"}], 
         "]"}], "<>", "\"\<\\t\>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Im", "[", 
          RowBox[{"s$n0", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"2", "*", "iQNM"}], "+", "1"}], "]"}], "]"}], "]"}], 
         "]"}], "<>", "\"\<\\n\>\""}], ",", "\n", 
       RowBox[{"\"\<N\\t\>\"", "<>", 
        RowBox[{"ToString", "[", "Nz", "]"}], "<>", "\"\<\\n\\n\>\""}]}], 
      "\n", "}"}]}], ";", "\n", "\n", 
    RowBox[{"fp", "=", 
     RowBox[{"OpenWrite", "[", "fn", "]"}]}], ";", "\n", 
    RowBox[{"Table", "[", " ", 
     RowBox[{
      RowBox[{"WriteString", "[", 
       RowBox[{"fp", ",", 
        RowBox[{"NumericalData", "[", 
         RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", 
        RowBox[{"Length", "@", "NumericalData"}]}], "}"}]}], "]"}], ";", "\n",
     "\n", 
    RowBox[{
     RowBox[{"WriteString", "[", 
      RowBox[{
      "fp", ",", 
       "\"\<#1:i\\t #2:Real(Cheb_phi_QNM)\\t #3:Imag(Cheb_phi_QNM)\\n\>\""}], 
      "]"}], "\n", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "0"}], ",", " ", 
       RowBox[{"i", "<=", "Nz"}], ",", " ", 
       RowBox[{"i", "++"}], ",", "\n", 
       RowBox[{"WriteString", "[", 
        RowBox[{"fp", ",", 
         RowBox[{"ToString", "[", "i", "]"}], ",", "\"\<\\t\>\"", ",", "\n", 
         RowBox[{"ToString", "[", 
          RowBox[{
           RowBox[{"Re", "[", 
            RowBox[{"cheb$\[Phi]QNM$dom0", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{
                RowBox[{"2", "*", "iQNM"}], "+", "1"}], ",", 
               RowBox[{"i", "+", "1"}]}], "]"}], "]"}], "]"}], ",", "CForm"}],
           "]"}], ",", "\"\<\\t\>\"", ",", " ", 
         RowBox[{"ToString", "[", 
          RowBox[{
           RowBox[{"Im", "[", 
            RowBox[{"cheb$\[Phi]QNM$dom0", "[", 
