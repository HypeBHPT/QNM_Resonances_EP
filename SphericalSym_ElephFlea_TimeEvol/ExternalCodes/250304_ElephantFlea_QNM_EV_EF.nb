Cell[CellGroupData[{

Cell["Chebyshev Coefficients", "Subsubsection",ExpressionUUID->"baa323c9-1aac-49b3-9df7-947911c4f14b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ChebGaussCoefficients", "[", 
     RowBox[{"f_", ",", " ", "Prec_"}], "]"}], ":=", 
    RowBox[{"Module", "[", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"nf", ",", " ", "Nf", ",", "c", ",", "x"}], "}"}], ",", "\n", 
      RowBox[{
       RowBox[{"nf", "=", 
        RowBox[{"Length", "@", "f"}]}], ";", "\n", 
       RowBox[{"Nf", "=", 
        RowBox[{"nf", "-", "1"}]}], ";", "\n", "\n", 
       RowBox[{
        RowBox[{"x", "[", "j_", "]"}], ":=", 
        RowBox[{"N", "[", " ", 
         RowBox[{
          RowBox[{"Cos", "[", 
           RowBox[{"Pi", "*", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"j", "+", 
               RowBox[{"1", "/", "2"}]}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"Nf", "+", "1"}], ")"}]}]}], "]"}], " ", ",", "Prec"}], 
         "]"}]}], ";", "\n", "\n", 
       RowBox[{"c", "=", 
        RowBox[{"Table", "[", "  ", 
         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"f", "[", 
                RowBox[{"[", 
                 RowBox[{"j", "+", "1"}], "]"}], "]"}], "*", 
               RowBox[{"ChebyshevT", "[", 
                RowBox[{"m", ",", 
                 RowBox[{"x", "[", "j", "]"}]}], "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"j", ",", "0", ",", "Nf"}], "}"}]}], "]"}], "  ", "/", 
            "nf"}]}], "        ", ",", 
          RowBox[{"{", 
           RowBox[{"m", ",", "0", ",", "Nf"}], "}"}]}], "]"}]}]}]}], "\n", 
     "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ChebLobattoCoefficients", "[", 
    RowBox[{"f_", ",", " ", "Prec_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\n", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"nf", ",", " ", "Nf", ",", "c", ",", "x"}], "}"}], ",", "\n", 
     RowBox[{
      RowBox[{"nf", "=", 
       RowBox[{"Length", "@", "f"}]}], ";", "\n", 
      RowBox[{"Nf", "=", 
       RowBox[{"nf", "-", "1"}]}], ";", "\n", "\n", 
      RowBox[{
       RowBox[{"x", "[", "j_", "]"}], ":=", 
       RowBox[{"N", "[", 
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"j", " ", 
           RowBox[{"\[Pi]", "/", "Nf"}]}], "]"}], ",", "Prec"}], "]"}]}], ";",
       "\n", "\n", 
      RowBox[{"c", "=", 
       RowBox[{"Table", "[", "  ", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", " ", 
            RowBox[{"2", "-", 
             RowBox[{"KroneckerDelta", "[", 
              RowBox[{"m", ",", "Nf"}], "]"}]}], ")"}], " ", "/", 
           RowBox[{"(", 
            RowBox[{"2", "Nf"}], ")"}]}], " ", 
          RowBox[{"(", "  ", 
           RowBox[{
            RowBox[{"f", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "+", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"-", "1"}], ")"}], "^", "m"}], " ", 
             RowBox[{"f", "[", 
              RowBox[{"[", "nf", "]"}], "]"}]}], " ", "+", " ", 
            RowBox[{"2", " ", 
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"f", "[", 
                 RowBox[{"[", 
                  RowBox[{"j", "+", "1"}], "]"}], "]"}], "*", 
                RowBox[{"ChebyshevT", "[", 
                 RowBox[{"m", ",", 
                  RowBox[{"x", "[", "j", "]"}]}], "]"}]}], ",", 
               RowBox[{"{", 
                RowBox[{"j", ",", "1", ",", 
                 RowBox[{"Nf", "-", "1"}]}], "}"}]}], "]"}]}]}], "  ", 
           ")"}]}], "        ", ",", 
         RowBox[{"{", 
          RowBox[{"m", ",", "0", ",", "Nf"}], "}"}]}], "]"}]}]}]}], "\n", 
    "]"}]}], ";"}]}], "Code",
