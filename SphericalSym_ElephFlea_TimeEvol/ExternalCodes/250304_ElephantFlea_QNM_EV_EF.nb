 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"DefiniteIntegral", "[", 
     RowBox[{"c_", ",", "a_", ",", "b_"}], "]"}], ":=", 
    RowBox[{"Module", "[", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"kf", ",", "nc", ",", "Nc", ",", " ", "Int"}], "}"}], ",", 
      "\n", 
      RowBox[{
       RowBox[{"nc", "=", 
        RowBox[{"Length", "@", "c"}]}], ";", "\n", 
       RowBox[{"Nc", "=", 
        RowBox[{"nc", "-", "1"}]}], ";", "\n", 
       RowBox[{"kf", "=", 
        RowBox[{"Floor", "[", 
         RowBox[{"Nc", "/", "2"}], "]"}]}], ";", "\n", 
       RowBox[{"Int", "=", 
        RowBox[{
         RowBox[{"c", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "-", " ", 
         RowBox[{"2", 
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"c", "[", 
              RowBox[{"[", 
               RowBox[{
                RowBox[{"2", " ", "k"}], " ", "+", "1"}], "]"}], "]"}], "/", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"4", " ", 
                RowBox[{"k", " ", "^", "2"}]}], " ", "-", "1"}], ")"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", "1", ",", "kf"}], "}"}]}], "]"}]}]}]}], ";", 
       "\n", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"b", "-", "a"}], ")"}], "*", 
        RowBox[{"Int", "/", "2"}]}]}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"ChebyLobattoHilbertIntegration", "[", 
   RowBox[{"z_", ",", "Nz_", ",", "Prec_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\n", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"i", ",", "j"}], "}"}], ",", "\n", 
    RowBox[{"Table", "[", "\n", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"i", "!=", "j"}], ",", "\n", "0", ",", "\n", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"i", "==", "0"}], " ", "||", " ", 
           RowBox[{"i", "==", "Nz"}]}], ",", "\n", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"1", "/", "Nz"}], " ", "-", " ", 
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"2", "-", 
                 RowBox[{"KroneckerDelta", "[", 
                  RowBox[{
                   RowBox[{"2", "k"}], ",", "Nz"}], "]"}]}], ")"}], "/", 
               RowBox[{"(", 
                RowBox[{"Nz", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"4", 
                    RowBox[{"k", "^", "2"}]}], "-", "1"}], ")"}]}], ")"}]}], 
              ",", 
              RowBox[{"{", 
               RowBox[{"k", ",", "1", ",", 
                RowBox[{"Floor", "[", 
                 RowBox[{"Nz", "/", "2"}], "]"}]}], "}"}]}], "]"}]}], ")"}], 
          ",", "\n", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "/", "Nz"}], " ", "-", " ", 
            RowBox[{"2", 
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"2", "-", 
                  RowBox[{"KroneckerDelta", "[", 
                   RowBox[{
                    RowBox[{"2", "k"}], ",", "Nz"}], "]"}]}], ")"}], "*", 
                RowBox[{
                 RowBox[{"ChebyshevT", "[", 
                  RowBox[{
                   RowBox[{"2", "k"}], ",", 
                   RowBox[{"z", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", "+", "1"}], "]"}], "]"}]}], "]"}], "/", 
                 RowBox[{"(", 
                  RowBox[{"Nz", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"4", 
