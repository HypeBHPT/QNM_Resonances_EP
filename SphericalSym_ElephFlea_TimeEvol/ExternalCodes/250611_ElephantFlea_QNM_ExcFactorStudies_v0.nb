           RowBox[{"\[Pi]", "/", "Nf"}]}], "]"}], ",", "Prec"}], "]"}]}], ";",
       "\n", "\n", 
      RowBox[{"c", "=", 
       RowBox[{"Table", "[", "  ", 
        RowBox[{
