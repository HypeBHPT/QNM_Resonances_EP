Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"h$Interference", "=", 
   RowBox[{
    RowBox[{"-", "2"}], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "sR"}], " ", "\[Tau]"}]], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Delta]\[Rho]", " ", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"\[Delta]sR", " ", "\[Tau]"}]}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"\[Delta]sI", " ", "\[Delta]\[Phi]", " ", "\[Tau]"}]}], 
           ")"}]}], "+", 
         RowBox[{"\[Rho]0", " ", "\[Tau]", " ", 
          RowBox[{"(", 
           RowBox[{"\[Delta]sR", "+", 
            RowBox[{"\[Delta]sI", " ", "\[Delta]\[Phi]"}], "+", 
            RowBox[{
            "\[Delta]sI", " ", "\[Delta]sR", " ", "\[Delta]\[Phi]", " ", 
             "\[Tau]"}]}], ")"}]}]}], ")"}], " ", 
       RowBox[{"Cos", "[", 
        RowBox[{
         RowBox[{"sI", " ", "\[Tau]"}], "+", "\[Phi]0"}], "]"}]}], "+", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "sR"}], " ", "\[Tau]"}]], " ", 
       RowBox[{"(", 
        RowBox[{"\[Delta]\[Rho]", "+", "\[Rho]0"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"\[Delta]\[Phi]", "-", 
         RowBox[{"\[Delta]sI", " ", "\[Tau]"}]}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"\[Delta]sR", " ", "\[Tau]"}]}], ")"}], " ", 
       RowBox[{"Sin", "[", 
        RowBox[{
         RowBox[{"sI", " ", "\[Tau]"}], "+", "\[Phi]0"}], "]"}]}]}], 
     ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"PlotInterference", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{"h$Interference", ",", 
    RowBox[{"{", 
     RowBox[{"\[Tau]", ",", "0", ",", "50"}], "}"}], ",", " ", 
    RowBox[{"PlotStyle", "->", 
     RowBox[{"{", 
      RowBox[{"Red", ",", "Dashed"}], "}"}]}], ",", " ", 
    RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"InterferenceError", "=", 
   RowBox[{"Abs", "[", 
    RowBox[{"1", "-", 
     RowBox[{"h$Interference", "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"hQNM$Scri", "[", 
         RowBox[{"\[Tau]", ",", "3"}], "]"}], "+", 
        RowBox[{"hQNM$Scri", "[", 
         RowBox[{"\[Tau]", ",", "4"}], "]"}]}], ")"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"PlotError", "=", 
  RowBox[{"LogPlot", "[", 
   RowBox[{"InterferenceError", ",", 
    RowBox[{"{", 
     RowBox[{"\[Tau]", ",", "0", ",", "50"}], "}"}], ",", " ", 
    RowBox[{"PlotStyle", "->", 
     RowBox[{"{", "Black", "}"}]}], ",", " ", 
    RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"PlotFreqEvol", ",", "PlotInterference"}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
