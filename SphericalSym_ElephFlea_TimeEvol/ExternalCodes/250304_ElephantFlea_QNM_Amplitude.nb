 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"spin", "==", "0"}], ",", 
    RowBox[{"VRW", "=", 
     RowBox[{
      RowBox[{"a", "/", 
       RowBox[{"r", "^", "2"}]}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "*", 
         RowBox[{"(", 
