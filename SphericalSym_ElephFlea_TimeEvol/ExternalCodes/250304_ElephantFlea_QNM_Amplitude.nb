Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"WaveSimplePole", "=", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[Eta]A", "*", 
       RowBox[{"Exp", "[", 
        RowBox[{"sA", "*", "t"}], "]"}]}], "+", 
      RowBox[{"c\[Eta]A", "*", 
       RowBox[{"Exp", "[", 
        RowBox[{"csA", "*", "t"}], "]"}]}], "+", 
      RowBox[{"\[Eta]B", "*", 
       RowBox[{"Exp", "[", 
        RowBox[{"sB", "*", "t"}], "]"}]}], "+", 
      RowBox[{"c\[Eta]B", "*", 
       RowBox[{"Exp", "[", 
        RowBox[{"csB", "*", "t"}], "]"}]}]}], ")"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"WaveDoublePole", "=", 
   RowBox[{
    RowBox[{"BEP", "*", 
     RowBox[{"(", 
      RowBox[{"1", "+", "  ", 
       RowBox[{"bb", " ", "*", " ", "sEP", " ", "*", " ", "t"}]}], ")"}], 
     RowBox[{"Exp", "[", 
      RowBox[{"sEP", "*", "t"}], "]"}]}], "+", 
    RowBox[{"cBEP", "*", 
     RowBox[{"(", 
      RowBox[{"1", "+", "  ", 
       RowBox[{"cbb", " ", "*", " ", "csEP", " ", "*", " ", "t"}]}], ")"}], 
     RowBox[{"Exp", "[", 
      RowBox[{"csEP", "*", "t"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"WaveLinear", "=", 
    RowBox[{
     RowBox[{"BEP", "*", 
      RowBox[{"(", " ", 
       RowBox[{"(*", 
        RowBox[{"1", "+"}], " ", "*)"}], 
       RowBox[{" ", "bb", " ", "*", " ", "sEP", " ", "*", " ", "t"}], ")"}], 
      RowBox[{"Exp", "[", 
       RowBox[{"sEP", "*", "t"}], "]"}]}], "+", 
     RowBox[{"cBEP", "*", 
      RowBox[{"(", 
       RowBox[{"(*", 
        RowBox[{"1", "+"}], " ", "*)"}], 
       RowBox[{" ", "cbb", " ", "*", " ", "csEP", " ", "*", " ", "t"}], ")"}], 
      RowBox[{"Exp", "[", 
       RowBox[{"csEP", "*", "t"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PlotSimplePole", "=", 
   RowBox[{"LogPlot", "[", 
    RowBox[{
     RowBox[{"Abs", "@", "WaveSimplePole"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "100"}], "}"}], ",", " ", 
     RowBox[{"PlotRange", "->", "All"}], ",", " ", 
     RowBox[{"PlotStyle", "->", "Red"}], ",", " ", 
     RowBox[{"PlotLabels", "->", "\"\<Simple Pole Model\>\""}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PlotDoublePole", "=", 
   RowBox[{"LogPlot", "[", 
    RowBox[{
     RowBox[{"Abs", "@", "WaveDoublePole"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "100"}], "}"}], ",", " ", 
     RowBox[{"PlotRange", "->", "All"}], ",", " ", 
     RowBox[{"PlotStyle", "->", "Orange"}], ",", " ", 
     RowBox[{"PlotLabels", "->", "\"\<Double Pole Model\>\""}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"PlotLinear", "=", 
    RowBox[{"LogPlot", "[", 
     RowBox[{
      RowBox[{"Abs", "@", "WaveLinear"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "100"}], "}"}], ",", " ", 
      RowBox[{"PlotRange", "->", "All"}], ",", " ", 
      RowBox[{"PlotStyle", "->", "Brown"}], ",", " ", 
      RowBox[{"PlotLabels", "->", "\"\<Double Pole Model\>\""}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"PlotSimplePoleData", "=", 
    RowBox[{"ListLogPlot", "[", 
     RowBox[{
      RowBox[{"Transpose", "@", 
       RowBox[{"{", 
        RowBox[{"Time", ",", 
         RowBox[{"Abs", "@", "Wave0"}]}], "}"}]}], ",", " ", 
      RowBox[{"PlotRange", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "110"}], "}"}], ",", 
