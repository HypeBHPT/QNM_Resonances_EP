         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"f", "[", 
                RowBox[{"[", 
                 RowBox[{"j", "+", "1"}], "]"}], "]"}], "*", 
               RowBox[{"ChebyshevT", "[", 
                RowBox[{"m", ",", 
                 RowBox[{"x", "[", "j", "]"}]}], "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"j", ",", "0", ",", "Nf"}], "}"}]}], "]"}], "  ", "/", 
            "nf"}]}], "        ", ",", 
          RowBox[{"{", 
           RowBox[{"m", ",", "0", ",", "Nf"}], "}"}]}], "]"}]}]}]}], "\n", 
     "]"}]}], ";"}], "\n"}], "\n", 
