Cell[CellGroupData[{

Cell["Poor-man Routine to read local maximum", "Subsubsection",
 CellChangeTimes->{{3.735365617040401*^9, 3.7353656219002533`*^9}, 
   3.7353799051183443`*^9, 
   3.735379936442782*^9},ExpressionUUID->"c427fdc6-990a-45b6-816f-\
aa9a5b5160cb"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"kmax", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"kk", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MaxPos", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"While", "[", 
  RowBox[{
   RowBox[{"kk", "<", "NData"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"k", "=", 
       RowBox[{"kmax", "+", "1"}]}], ",", " ", 
      RowBox[{"k", "<", "NData"}], ",", " ", 
      RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Fm1", "=", 
        RowBox[{"Abs", "@", 
         RowBox[{"Data", "[", 
          RowBox[{"[", 
           RowBox[{"k", "-", "1"}], "]"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"F", "=", 
        RowBox[{"Abs", "@", 
         RowBox[{"Data", "[", 
          RowBox[{"[", "k", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Fp1", "=", 
        RowBox[{"Abs", "@", 
         RowBox[{"Data", "[", 
          RowBox[{"[", 
           RowBox[{"k", "+", "1"}], "]"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"F", ">", "Fm1"}], " ", "&&", " ", 
          RowBox[{"F", ">", "Fp1"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"kmaxt", "=", "k"}], ";", "\[IndentingNewLine]", 
          RowBox[{"Break", "[", "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
       ";"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"kmax", "=", "kmaxt"}], ";", "\[IndentingNewLine]", 
    RowBox[{"MaxPos", "=", 
     RowBox[{"Append", "[", 
      RowBox[{"MaxPos", ",", "kmax"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"kk", "=", "k"}], ";"}]}], "\[IndentingNewLine]", 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MaxSize", "=", 
   RowBox[{"Length", "@", "MaxPos"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MaxData", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"tData", "[", 
        RowBox[{"[", 
         RowBox[{"MaxPos", "[", 
          RowBox[{"[", "n", "]"}], "]"}], "]"}], "]"}], ",", 
       RowBox[{"Abs", "@", 
        RowBox[{"Data", "[", 
         RowBox[{"[", 
          RowBox[{"MaxPos", "[", 
           RowBox[{"[", "n", "]"}], "]"}], "  ", "]"}], "]"}]}]}], "}"}], ",",
      " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "MaxSize"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PlotMax", "=", 
   RowBox[{"ListLogPlot", "[", 
    RowBox[{"MaxData", ",", " ", 
     RowBox[{"PlotRange", "\[Rule]", "Full"}], ",", " ", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"PointSize", "[", "Medium", "]"}]}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"PlotData", ",", "PlotMax"}], "]"}], "\[IndentingNewLine]"}], "Code",\

