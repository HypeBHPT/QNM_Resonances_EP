Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ChebInterpolation", "[", 
     RowBox[{
     "c_", ",", "a_", ",", "b_", ",", "x_", ",", " ", "\[Kappa]_", ",", " ", 
      "xb_", ",", " ", "Prec_"}], "]"}], ":=", 
