Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ChebGaussCoefficients", "[", 
     RowBox[{"f_", ",", " ", "Prec_"}], "]"}], ":=", 
    RowBox[{"Module", "[", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"nf", ",", " ", "Nf", ",", "c", ",", "x"}], "}"}], ",", "\n", 
      RowBox[{
       RowBox[{"nf", "=", 
        RowBox[{"Length", "@", "f"}]}], ";", "\n", 
       RowBox[{"Nf", "=", 
        RowBox[{"nf", "-", "1"}]}], ";", "\n", "\n", 
       RowBox[{
        RowBox[{"x", "[", "j_", "]"}], ":=", 
        RowBox[{"N", "[", " ", 
         RowBox[{
          RowBox[{"Cos", "[", 
           RowBox[{"Pi", "*", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"j", "+", 
               RowBox[{"1", "/", "2"}]}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"Nf", "+", "1"}], ")"}]}]}], "]"}], " ", ",", "Prec"}], 
         "]"}]}], ";", "\n", "\n", 
       RowBox[{"c", "=", 
