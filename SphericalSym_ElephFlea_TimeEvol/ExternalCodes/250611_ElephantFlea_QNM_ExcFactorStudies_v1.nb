Cell[CellGroupData[{

Cell["Spectral Differentiation matrices", "Subsubsection",ExpressionUUID->"6b581386-47ba-455a-b3f5-1eefca697bf5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DiffMatrix", "[", 
   RowBox[{"a_", ",", "b_", ",", "Nz_", ",", "Prec_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\n", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "k", ",", "i", ",", "j", ",", "dx", ",", " ", "\[CapitalDelta]", ",", 
      "Dy"}], "}"}], ",", "\n", "\n", 
    RowBox[{
     RowBox[{
      RowBox[{"k", "[", "i_", "]"}], ":=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"i", "*", 
          RowBox[{"(", 
           RowBox[{"i", "-", "Nz"}], ")"}]}], "==", "0"}], ",", " ", "2", ",",
         "1"}], "]"}]}], ";", "\n", 
     RowBox[{
      RowBox[{"dx", "[", 
       RowBox[{"i_", ",", "j_"}], "]"}], ":=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"i", "!=", "j"}], ",", "\n", 
        RowBox[{
         RowBox[{"k", "[", "i", "]"}], "*", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "^", 
           RowBox[{"(", 
            RowBox[{"i", "-", "j"}], ")"}]}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"k", "[", "j", "]"}], "*", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"x", "[", 
               RowBox[{"i", ",", "Nz"}], "]"}], "-", 
              RowBox[{"x", "[", 
               RowBox[{"j", ",", "Nz"}], "]"}]}], ")"}]}], ")"}]}]}], ",", 
        "\n", "0"}], "\n", "]"}]}], ";", "\n", 
     RowBox[{"\[CapitalDelta]", "=", 
      RowBox[{"b", "-", "a"}]}], ";", "\n", 
     RowBox[{"Dy", "=", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"2", "/", "\[CapitalDelta]"}], " ", "*", " ", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"dx", "[", 
            RowBox[{"i", ",", "j"}], "]"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"i", ",", "0", ",", "Nz"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"j", ",", "0", ",", "Nz"}], "}"}]}], "]"}]}], ",", 
        "Prec"}], " ", "]"}]}], ";", "\n", "\n", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "0"}], ",", " ", 
       RowBox[{"i", "<=", "Nz"}], ",", " ", 
       RowBox[{"i", "++"}], ",", "\n", 
       RowBox[{
        RowBox[{
         RowBox[{"Dy", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"i", "+", "1"}], ",", 
            RowBox[{"i", "+", "1"}]}], "]"}], "]"}], "=", " ", 
         RowBox[{"-", 
          RowBox[{"Sum", "[", " ", 
           RowBox[{
            RowBox[{"Dy", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"i", "+", "1"}], ",", 
               RowBox[{"j", "+", "1"}]}], "]"}], "]"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"j", ",", "0", ",", "Nz"}], "}"}]}], " ", "]"}]}]}], 
        ";"}]}], "\n", "]"}], ";", "\n", "Dy"}]}], "\n", "]"}]}]], "Code",
 CellLabel->
  "In[248]:=",ExpressionUUID->"70db45cc-e49b-4ea1-89aa-100a93848f12"]
}, Closed]],

