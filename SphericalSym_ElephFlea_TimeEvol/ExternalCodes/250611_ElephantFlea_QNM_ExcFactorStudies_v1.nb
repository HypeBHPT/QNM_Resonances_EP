                RowBox[{"(", 
                 RowBox[{"2", "-", 
                  RowBox[{"KroneckerDelta", "[", 
                   RowBox[{"j", ",", "Nl"}], "]"}]}], ")"}], " ", 
                RowBox[{"ChebyshevT", "[", 
                 RowBox[{"j", ",", 
                  RowBox[{"xl", "[", 
