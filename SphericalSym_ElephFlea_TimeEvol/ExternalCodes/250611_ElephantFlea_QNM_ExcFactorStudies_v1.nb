Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ChebInterpolation", "[", 
     RowBox[{
     "c_", ",", "a_", ",", "b_", ",", "x_", ",", " ", "\[Kappa]_", ",", " ", 
      "xb_", ",", " ", "Prec_"}], "]"}], ":=", 
    RowBox[{"Module", "[", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"nc", ",", " ", "Nc", ",", " ", "\[Chi]", ",", " ", "y"}], 
       "}"}], ",", "\n", 
      RowBox[{
       RowBox[{"nc", "=", 
        RowBox[{"Length", "@", "c"}]}], ";", "\n", 
       RowBox[{"Nc", "=", 
        RowBox[{"nc", "-", "1"}]}], ";", "\n", "\n", 
       RowBox[{"y", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", " ", "x"}], "-", 
           RowBox[{"(", 
            RowBox[{"a", "+", "b"}], ")"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"b", "-", "a"}], ")"}]}]}], ";", "\n", 
       RowBox[{"\[Chi]", "=", 
        RowBox[{"\[Chi]$of$x", "[", 
         RowBox[{"y", ",", "\[Kappa]", ",", "xb"}], "]"}]}], ";", "\n", "\n", 
       
       RowBox[{
        RowBox[{
         RowBox[{"c", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "/", "2"}], "+", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"c", "[", 
            RowBox[{"[", 
             RowBox[{"i", "+", "1"}], "]"}], "]"}], "*", 
           RowBox[{"ChebyshevT", "[", 
            RowBox[{"i", ",", "\[Chi]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "Nc"}], "}"}]}], "]"}]}]}]}], "\n", 
     "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ChebyLobattoInterpolationVector", "[", 
     RowBox[{"xl_", ",", "Nl_", ",", "x\[Alpha]_", ",", "Prec_"}], "]"}], ":=", 
    RowBox[{"Module", "[", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", "l"}], "}"}], ",", "\n", 
      RowBox[{"Table", "[", "\n", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"l", "==", "0"}], ",", "\n", 
          RowBox[{
           RowBox[{"1", "/", 
            RowBox[{"(", 
             RowBox[{"2", "Nl"}], ")"}]}], "+", 
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"2", "-", 
                RowBox[{"KroneckerDelta", "[", 
                 RowBox[{"j", ",", "Nl"}], "]"}]}], ")"}], 
              RowBox[{
               RowBox[{"ChebyshevT", "[", 
                RowBox[{"j", ",", "x\[Alpha]"}], "]"}], "/", 
               RowBox[{"(", 
                RowBox[{"2", "Nl"}], ")"}]}]}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", "Nl"}], "}"}]}], "]"}]}], ",", "\n", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"l", "==", "Nl"}], ",", "\n", 
            RowBox[{
             RowBox[{"1", "/", 
              RowBox[{"(", 
               RowBox[{"2", "Nl"}], ")"}]}], "+", 
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"2", "-", 
                  RowBox[{"KroneckerDelta", "[", 
                   RowBox[{"j", ",", "Nl"}], "]"}]}], ")"}], 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"-", "1"}], ")"}], "^", "j"}], " ", 
                RowBox[{
                 RowBox[{"ChebyshevT", "[", 
                  RowBox[{"j", ",", "x\[Alpha]"}], "]"}], "/", 
                 RowBox[{"(", 
                  RowBox[{"2", "Nl"}], ")"}]}]}], ",", 
               RowBox[{"{", 
                RowBox[{"j", ",", "1", ",", "Nl"}], "}"}]}], "]"}]}], ",", 
            "\n", 
            RowBox[{
             RowBox[{"1", "/", 
              RowBox[{"(", "Nl", ")"}]}], "+", 
