                RowBox[{"j", ",", "1", ",", "Nl"}], "}"}]}], "]"}]}]}], "\n", 
           "]"}]}], "\n", "]"}], ",", "\n", 
        RowBox[{"{", 
         RowBox[{"l", ",", "0", ",", "Nl"}], "}"}]}], "\n", "]"}]}], "\n", 
     "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"ChebyLobattoInterpolationMatrix", "[", 
   RowBox[{
