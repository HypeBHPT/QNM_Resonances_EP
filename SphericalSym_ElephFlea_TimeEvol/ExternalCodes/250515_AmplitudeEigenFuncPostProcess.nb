Cell[CellGroupData[{

Cell["Spectral Differentiation matrices", "Subsubsection",ExpressionUUID->"e6255066-39e3-4e48-82aa-9f32d747b429"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DiffMatrix", "[", 
   RowBox[{"a_", ",", "b_", ",", "Nz_", ",", "Prec_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\n", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "k", ",", "i", ",", "j", ",", "dx", ",", " ", "\[CapitalDelta]", ",", 
      "Dy"}], "}"}], ",", "\n", "\n", 
    RowBox[{
     RowBox[{
      RowBox[{"k", "[", "i_", "]"}], ":=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"i", "*", 
          RowBox[{"(", 
           RowBox[{"i", "-", "Nz"}], ")"}]}], "==", "0"}], ",", " ", "2", ",",
         "1"}], "]"}]}], ";", "\n", 
     RowBox[{
      RowBox[{"dx", "[", 
       RowBox[{"i_", ",", "j_"}], "]"}], ":=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"i", "!=", "j"}], ",", "\n", 
        RowBox[{
         RowBox[{"k", "[", "i", "]"}], "*", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "^", 
           RowBox[{"(", 
            RowBox[{"i", "-", "j"}], ")"}]}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"k", "[", "j", "]"}], "*", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"x", "[", 
               RowBox[{"i", ",", "Nz"}], "]"}], "-", 
              RowBox[{"x", "[", 
               RowBox[{"j", ",", "Nz"}], "]"}]}], ")"}]}], ")"}]}]}], ",", 
        "\n", "0"}], "\n", "]"}]}], ";", "\n", 
     RowBox[{"\[CapitalDelta]", "=", 
      RowBox[{"b", "-", "a"}]}], ";", "\n", 
     RowBox[{"Dy", "=", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"2", "/", "\[CapitalDelta]"}], " ", "*", " ", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"dx", "[", 
            RowBox[{"i", ",", "j"}], "]"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"i", ",", "0", ",", "Nz"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"j", ",", "0", ",", "Nz"}], "}"}]}], "]"}]}], ",", 
        "Prec"}], " ", "]"}]}], ";", "\n", "\n", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "0"}], ",", " ", 
       RowBox[{"i", "<=", "Nz"}], ",", " ", 
       RowBox[{"i", "++"}], ",", "\n", 
       RowBox[{
        RowBox[{
         RowBox[{"Dy", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"i", "+", "1"}], ",", 
            RowBox[{"i", "+", "1"}]}], "]"}], "]"}], "=", " ", 
         RowBox[{"-", 
          RowBox[{"Sum", "[", " ", 
           RowBox[{
            RowBox[{"Dy", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"i", "+", "1"}], ",", 
               RowBox[{"j", "+", "1"}]}], "]"}], "]"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"j", ",", "0", ",", "Nz"}], "}"}]}], " ", "]"}]}]}], 
        ";"}]}], "\n", "]"}], ";", "\n", "Dy"}]}], "\n", "]"}]}]], "Code",
 CellLabel->
  "In[381]:=",ExpressionUUID->"608ccb4d-14d7-4c31-8f97-087dc3ff4673"]
}, Closed]],

Cell[CellGroupData[{

Cell["Chebyshev Interpolation", "Subsubsection",ExpressionUUID->"69b9c533-c31d-48e3-931f-c52a42614cb5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ChebInterpolation", "[", 
     RowBox[{
     "c_", ",", "a_", ",", "b_", ",", "x_", ",", " ", "\[Kappa]_", ",", " ", 
      "xb_", ",", " ", "Prec_"}], "]"}], ":=", 
    RowBox[{"Module", "[", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"nc", ",", " ", "Nc", ",", " ", "\[Chi]", ",", " ", "y"}], 
       "}"}], ",", "\n", 
      RowBox[{
       RowBox[{"nc", "=", 
        RowBox[{"Length", "@", "c"}]}], ";", "\n", 
       RowBox[{"Nc", "=", 
        RowBox[{"nc", "-", "1"}]}], ";", "\n", "\n", 
       RowBox[{"y", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", " ", "x"}], "-", 
           RowBox[{"(", 
            RowBox[{"a", "+", "b"}], ")"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"b", "-", "a"}], ")"}]}]}], ";", "\n", 
       RowBox[{"\[Chi]", "=", 
        RowBox[{"\[Chi]$of$x", "[", 
         RowBox[{"y", ",", "\[Kappa]", ",", "xb"}], "]"}]}], ";", "\n", "\n", 
       
       RowBox[{
        RowBox[{
         RowBox[{"c", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "/", "2"}], "+", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"c", "[", 
            RowBox[{"[", 
             RowBox[{"i", "+", "1"}], "]"}], "]"}], "*", 
           RowBox[{"ChebyshevT", "[", 
            RowBox[{"i", ",", "\[Chi]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "Nc"}], "}"}]}], "]"}]}]}]}], "\n", 
     "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ChebyLobattoInterpolationVector", "[", 
     RowBox[{"xl_", ",", "Nl_", ",", "x\[Alpha]_", ",", "Prec_"}], "]"}], ":=", 
    RowBox[{"Module", "[", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", "l"}], "}"}], ",", "\n", 
      RowBox[{"Table", "[", "\n", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"l", "==", "0"}], ",", "\n", 
          RowBox[{
           RowBox[{"1", "/", 
            RowBox[{"(", 
             RowBox[{"2", "Nl"}], ")"}]}], "+", 
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"2", "-", 
                RowBox[{"KroneckerDelta", "[", 
                 RowBox[{"j", ",", "Nl"}], "]"}]}], ")"}], 
              RowBox[{
               RowBox[{"ChebyshevT", "[", 
                RowBox[{"j", ",", "x\[Alpha]"}], "]"}], "/", 
               RowBox[{"(", 
                RowBox[{"2", "Nl"}], ")"}]}]}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", "Nl"}], "}"}]}], "]"}]}], ",", "\n", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"l", "==", "Nl"}], ",", "\n", 
            RowBox[{
             RowBox[{"1", "/", 
              RowBox[{"(", 
               RowBox[{"2", "Nl"}], ")"}]}], "+", 
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"2", "-", 
                  RowBox[{"KroneckerDelta", "[", 
                   RowBox[{"j", ",", "Nl"}], "]"}]}], ")"}], 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"-", "1"}], ")"}], "^", "j"}], " ", 
                RowBox[{
                 RowBox[{"ChebyshevT", "[", 
                  RowBox[{"j", ",", "x\[Alpha]"}], "]"}], "/", 
                 RowBox[{"(", 
                  RowBox[{"2", "Nl"}], ")"}]}]}], ",", 
               RowBox[{"{", 
                RowBox[{"j", ",", "1", ",", "Nl"}], "}"}]}], "]"}]}], ",", 
            "\n", 
            RowBox[{
             RowBox[{"1", "/", 
              RowBox[{"(", "Nl", ")"}]}], "+", 
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"2", "-", 
                  RowBox[{"KroneckerDelta", "[", 
                   RowBox[{"j", ",", "Nl"}], "]"}]}], ")"}], " ", 
                RowBox[{"ChebyshevT", "[", 
                 RowBox[{"j", ",", 
                  RowBox[{"xl", "[", 
                   RowBox[{"[", 
                    RowBox[{"l", "+", "1"}], "]"}], "]"}]}], "]"}], 
                RowBox[{
                 RowBox[{"ChebyshevT", "[", 
                  RowBox[{"j", ",", "x\[Alpha]"}], "]"}], "/", 
                 RowBox[{"(", "Nl", ")"}]}]}], ",", 
               RowBox[{"{", 
                RowBox[{"j", ",", "1", ",", "Nl"}], "}"}]}], "]"}]}]}], "\n", 
           "]"}]}], "\n", "]"}], ",", "\n", 
        RowBox[{"{", 
         RowBox[{"l", ",", "0", ",", "Nl"}], "}"}]}], "\n", "]"}]}], "\n", 
     "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"ChebyLobattoInterpolationMatrix", "[", 
   RowBox[{
   "xl_", ",", "Nl_", ",", "x\[Alpha]_", ",", "N\[Alpha]_", ",", "Prec_"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", "\n", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Alpha]", ",", "l"}], "}"}], ",", "\n", 
