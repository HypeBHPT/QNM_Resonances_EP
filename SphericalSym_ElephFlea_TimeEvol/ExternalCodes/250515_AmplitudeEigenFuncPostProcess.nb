Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"x$of$\[Chi]", "[", 
    RowBox[{"\[Chi]_", ",", "\[Kappa]_", ",", "xb_"}], "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"\[Kappa]", "==", "0"}], ",", "\[Chi]", ",", " ", 
     RowBox[{"xb", 
      RowBox[{"(", 
       RowBox[{"1", "-", " ", 
        RowBox[{"2", " ", 
         RowBox[{
          RowBox[{"Sinh", "[", " ", 
           RowBox[{"\[Kappa]", " ", 
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{"xb", " ", "\[Chi]"}]}], ")"}]}], "]"}], "/", 
          RowBox[{"Sinh", "[", 
           RowBox[{"2", "\[Kappa]"}], "]"}]}]}]}], "    ", ")"}]}]}], "]"}]}],
   ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Chi]$of$x", "[", 
    RowBox[{"X_", ",", "\[Kappa]_", ",", "xb_"}], "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"\[Kappa]", "==", "0"}], ",", "X", ",", " ", 
     RowBox[{"xb", "*", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{
         RowBox[{"ArcSinh", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", " ", "-", " ", 
             RowBox[{"X", "*", "xb"}]}], ")"}], "*", 
           RowBox[{
            RowBox[{"Sinh", "[", 
             RowBox[{"2", "\[Kappa]"}], "]"}], "/", "2"}]}], "]"}], "/", 
         "\[Kappa]"}]}], ")"}]}]}], "]"}]}], ";"}]}], "Code",
 CellChangeTimes->{{3.950077412792302*^9, 3.95007746153799*^9}, 
   3.950077559379328*^9, {3.9500776422852592`*^9, 3.950077896095845*^9}, {
