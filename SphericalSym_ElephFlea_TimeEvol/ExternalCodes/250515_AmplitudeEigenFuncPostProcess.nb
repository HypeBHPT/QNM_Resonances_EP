Cell[CellGroupData[{

Cell["Chebyshev Integration", "Subsubsection",ExpressionUUID->"653f40d2-ef85-4ee0-ac85-0a16634a3e38"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"DefiniteIntegral", "[", 
     RowBox[{"c_", ",", "a_", ",", "b_"}], "]"}], ":=", 
    RowBox[{"Module", "[", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"kf", ",", "nc", ",", "Nc", ",", " ", "Int"}], "}"}], ",", 
      "\n", 
      RowBox[{
       RowBox[{"nc", "=", 
        RowBox[{"Length", "@", "c"}]}], ";", "\n", 
       RowBox[{"Nc", "=", 
        RowBox[{"nc", "-", "1"}]}], ";", "\n", 
       RowBox[{"kf", "=", 
        RowBox[{"Floor", "[", 
