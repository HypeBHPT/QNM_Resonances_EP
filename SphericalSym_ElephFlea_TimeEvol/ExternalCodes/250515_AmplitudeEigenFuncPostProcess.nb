   RowBox[{"\[Kappa]$dom1", "[", "ao_", "]"}], ":=", 
   RowBox[{
    RowBox[{"125", "/", "100"}], " ", "*", " ", 
    RowBox[{"ao", "^", 
     RowBox[{"(", 
      RowBox[{"3", "/", "10"}], ")"}]}]}]}], ";"}]}], "Code",
