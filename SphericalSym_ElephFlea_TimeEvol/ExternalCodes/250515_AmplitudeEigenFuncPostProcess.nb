  RowBox[{
   RowBox[{
    RowBox[{"\[Kappa]$dom0", "[", "ao_", "]"}], ":=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"ao", "<", "10"}], ",", " ", "0", ",", "\n", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"10", "<=", "ao", "<=", "35"}], ",", 
        RowBox[{
         RowBox[{"77", "/", "100"}], " ", "+", " ", 
         RowBox[{
          RowBox[{"14", "/", "100"}], " ", 
          RowBox[{"Exp", "[", 
           RowBox[{"6", "*", 
            RowBox[{"ao", "/", "100"}]}], "]"}]}]}], ",", "2"}], "]"}]}], 
     "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"xb$dom1", "=", 
   RowBox[{"-", "1"}]}], ";"}], "\n", 
