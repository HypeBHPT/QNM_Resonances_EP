          RowBox[{"l", "==", "Nl"}], ",", "\n", 
          RowBox[{
           RowBox[{"1", "/", 
            RowBox[{"(", 
             RowBox[{"2", "Nl"}], ")"}]}], "+", 
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"2", "-", 
                RowBox[{"KroneckerDelta", "[", 
                 RowBox[{"j", ",", "Nl"}], "]"}]}], ")"}], 
