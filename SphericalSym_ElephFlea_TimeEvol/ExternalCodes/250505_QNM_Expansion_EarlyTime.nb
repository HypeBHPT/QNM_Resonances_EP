          RowBox[{"[", "n", "]"}], "]"}], "]"}], "]"}], ",", 
       RowBox[{"Abs", "@", 
        RowBox[{"Data", "[", 
         RowBox[{"[", 
          RowBox[{"MaxPos", "[", 
           RowBox[{"[", "n", "]"}], "]"}], "  ", "]"}], "]"}]}]}], "}"}], ",",
