Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"FourierPeriod", "=", 
    RowBox[{"Abs", "[", 
     RowBox[{"Fourier", "[", "Period", "]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"NFourier", "=", 
   RowBox[{"Length", "@", "FourierPeriod"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FourierPeriod1", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"FourierPeriod", "[", 
      RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{"NFourier", "/", "2"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FourierPeriod2", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"FourierPeriod", "[", 
      RowBox[{"[", 
       RowBox[{"i", "-", 
        RowBox[{"NFourier", "/", "2"}]}], "]"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{
        RowBox[{"NFourier", "/", "2"}], "+", "1"}], ",", "NFourier"}], 
      "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pos", " ", "=", " ", 
    RowBox[{
     RowBox[{"Position", "[", 
      RowBox[{"FourierPeriod1", ",", " ", 
       RowBox[{"Max", "[", "FourierPeriod1", "]"}]}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
