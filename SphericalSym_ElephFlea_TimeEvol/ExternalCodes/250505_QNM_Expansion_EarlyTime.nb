Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"hFIT", "=", 
  RowBox[{
   RowBox[{"A", "*", "exp", 
    RowBox[{"(", 
     RowBox[{"s0", "*", "t"}], ")"}]}], "+", 
   RowBox[{"B", "*", "exp", 
    RowBox[{"(", 
     RowBox[{"s1", "*", "t"}], ")"}]}]}]}]], "Input",
 CellChangeTimes->{{3.9507624659131603`*^9, 3.950762483224334*^9}},
