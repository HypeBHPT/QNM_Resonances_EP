Cell[BoxData[{
 RowBox[{
  RowBox[{"kmax", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"kk", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MaxPos", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"While", "[", 
  RowBox[{
   RowBox[{"kk", "<", "NData"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"k", "=", 
       RowBox[{"kmax", "+", "1"}]}], ",", " ", 
      RowBox[{"k", "<", "NData"}], ",", " ", 
      RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Fm1", "=", 
        RowBox[{"Abs", "@", 
         RowBox[{"Data", "[", 
          RowBox[{"[", 
           RowBox[{"k", "-", "1"}], "]"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"F", "=", 
        RowBox[{"Abs", "@", 
         RowBox[{"Data", "[", 
          RowBox[{"[", "k", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Fp1", "=", 
        RowBox[{"Abs", "@", 
         RowBox[{"Data", "[", 
          RowBox[{"[", 
           RowBox[{"k", "+", "1"}], "]"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"F", ">", "Fm1"}], " ", "&&", " ", 
          RowBox[{"F", ">", "Fp1"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"kmaxt", "=", "k"}], ";", "\[IndentingNewLine]", 
          RowBox[{"Break", "[", "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
       ";"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"kmax", "=", "kmaxt"}], ";", "\[IndentingNewLine]", 
    RowBox[{"MaxPos", "=", 
     RowBox[{"Append", "[", 
      RowBox[{"MaxPos", ",", "kmax"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"kk", "=", "k"}], ";"}]}], "\[IndentingNewLine]", 
  "]"}], "\[IndentingNewLine]", 
