 CellChangeTimes->{3.950854627426066*^9, 3.950855151368875*^9, 
  3.950861929993469*^9},
 CellLabel->
  "Out[286]=",ExpressionUUID->"c05705c2-8fa0-408c-ba6c-381a9aeb2600"]
}, Open  ]],

Cell["\<\
(i) We known s0 and s1 from freq. domain. Fit for A and B. Do we recover \
prediction from ID? Guess: Yes
(ii) Blind agnostic test: fit for (A,B, s0, s1). Do we recover the avoid \
crossing QNMs? Guess: No ?\
\>", "Text",
 CellChangeTimes->{{3.950762500161261*^9, 
  3.950762565265026*^9}},ExpressionUUID->"2af456a4-98c1-4ab8-bc83-\
ac3423a55c81"]
}, Open  ]]
}, Open  ]],

