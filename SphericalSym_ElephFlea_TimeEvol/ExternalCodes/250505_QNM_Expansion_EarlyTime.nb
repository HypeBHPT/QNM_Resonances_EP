Cell["\<\
Data Analysis (simple fit as easiest first option): \[LineSeparator](1) Blind \
test with unknown Amp and unknown \[Omega]\[LineSeparator](2) Schwarzschild \
test with unknown Amp, but \[Omega]_Schwarz
(3) Elephant Flea test with unknown Amp, but \[Omega]_ElFlea\
\>", "Text",
 CellChangeTimes->{{3.9501565853230343`*^9, 3.950156699749354*^9}, {
  3.9501567436918707`*^9, 
  3.950156744428616*^9}},ExpressionUUID->"d1ebb7a5-d7fc-41e0-810d-\
638a65dec73b"]
}, Open  ]],

