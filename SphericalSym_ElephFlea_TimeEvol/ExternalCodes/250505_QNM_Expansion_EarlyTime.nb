Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Data2Fit", "=", 
    RowBox[{"Transpose", "@", 
     RowBox[{"{", 
      RowBox[{"tData", ",", "Data"}], "}"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"nQNM$Fit", "=", "3"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"model", "=", 
  RowBox[{"Sum", " ", "[", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"A", "[", "i", "]"}], "*", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"\[Omega]i", "[", "i", "]"}]}], " ", "*", "t"}], "]"}], 
     RowBox[{"Sin", "[", 
      RowBox[{
       RowBox[{"\[Phi]", "[", "i", "]"}], "+", 
       RowBox[{
        RowBox[{"\[Omega]r", "[", "i", "]"}], "*", "t"}]}], "]"}]}], " ", ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "1", ",", "nQNM$Fit"}], "}"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"modelpar", "=", 
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"A", "[", "i", "]"}], ",", 
       RowBox[{"\[Phi]", "[", "i", "]"}], ",", 
       RowBox[{"\[Omega]i", "[", "i", "]"}], ",", " ", 
       RowBox[{"\[Omega]r", "[", "i", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "nQNM$Fit"}], "}"}]}], "]"}], "//", 
   "Flatten"}]}], "\[IndentingNewLine]", 
 RowBox[{"nlm", "=", 
  RowBox[{
   RowBox[{"NonlinearModelFit", "[", 
    RowBox[{"Data2Fit", ",", "model", ",", "modelpar", ",", "t", ",", " ", 
     RowBox[{"MaxIterations", "->", "Infinity"}], ",", " ", 
     RowBox[{"AccuracyGoal", "->", 
      RowBox[{"0.5", "*", "MachinePrecision"}]}], ",", " ", 
     RowBox[{"PrecisionGoal", "->", 
      RowBox[{"0.5", "*", "MachinePrecision"}]}], ",", "  ", 
     RowBox[{"WorkingPrecision", "->", "MachinePrecision"}]}], "]"}], "//", 
   "Normal"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nlm$data", "=", 
   RowBox[{"nlm", "/.", 
    RowBox[{"t", "->", "tData"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Residual", "=", 
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{"Data", "-", "nlm$data"}], "]"}], "/", 
