Cell["Map derivatives \[Delta]\[Chi] into \[Delta]x", "Subsubsection",ExpressionUUID->"eea2f02f-947a-4590-9d96-612bfc040a48"],

Cell["Domain 0", "Text",ExpressionUUID->"058bffbf-ccc8-45ff-a634-f74578139633"],

Cell[BoxData[
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"\[Kappa]$dom0", "==", "0"}], ",", "\n", 
    RowBox[{
     RowBox[{"Dx$dom0", "=", "D\[Chi]$dom0"}], ";", "\n", 
     RowBox[{"D2x$dom0", "=", "D2\[Chi]$dom0"}], ";"}], "\n", "\n", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"DxRef$dom0", "=", "D\[Chi]Ref$dom0"}], ";"}], "*)"}], "\n", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"D2xRef$dom0", "=", "D2\[Chi]Ref$dom0"}], ";"}], "*)"}], "\n", 
    "\n", ",", "\n", "\n", 
    RowBox[{
     RowBox[{"J", " ", "=", 
      RowBox[{"N", "[", " ", 
       RowBox[{
        RowBox[{"2", "*", "\[Kappa]$dom0", "*", 
         RowBox[{
          RowBox[{"Cosh", "[", 
           RowBox[{"\[Kappa]$dom0", "*", 
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{"\[Chi]$dom0", "*", "xb$dom0"}]}], ")"}]}], "]"}], "/", 
          
          RowBox[{"Sinh", "[", 
           RowBox[{"2", "*", "\[Kappa]$dom0"}], "]"}]}]}], ",", "Prec"}], 
       "]"}]}], ";", "\n", 
     RowBox[{"J2", " ", "=", 
      RowBox[{"N", "[", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "2"}], "*", 
         RowBox[{"\[Kappa]$dom0", "^", "2"}], "*", "xb$dom0", "*", 
