Cell[BoxData[{
 RowBox[{
  RowBox[{"h$Interference", "=", 
   RowBox[{
    RowBox[{"-", "2"}], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "sR"}], " ", "\[Tau]"}]], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Delta]\[Rho]", " ", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"\[Delta]sR", " ", "\[Tau]"}]}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"\[Delta]sI", " ", "\[Delta]\[Phi]", " ", "\[Tau]"}]}], 
           ")"}]}], "+", 
         RowBox[{"\[Rho]0", " ", "\[Tau]", " ", 
          RowBox[{"(", 
           RowBox[{"\[Delta]sR", "+", 
            RowBox[{"\[Delta]sI", " ", "\[Delta]\[Phi]"}], "+", 
            RowBox[{
            "\[Delta]sI", " ", "\[Delta]sR", " ", "\[Delta]\[Phi]", " ", 
             "\[Tau]"}]}], ")"}]}]}], ")"}], " ", 
       RowBox[{"Cos", "[", 
        RowBox[{
         RowBox[{"sI", " ", "\[Tau]"}], "+", "\[Phi]0"}], "]"}]}], "+", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "sR"}], " ", "\[Tau]"}]], " ", 
       RowBox[{"(", 
        RowBox[{"\[Delta]\[Rho]", "+", "\[Rho]0"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"\[Delta]\[Phi]", "-", 
         RowBox[{"\[Delta]sI", " ", "\[Tau]"}]}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"\[Delta]sR", " ", "\[Tau]"}]}], ")"}], " ", 
