Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"hFIT", "=", 
  RowBox[{
   RowBox[{"A", "*", "exp", 
    RowBox[{"(", 
     RowBox[{"s0", "*", "t"}], ")"}]}], "+", 
   RowBox[{"B", "*", "exp", 
    RowBox[{"(", 
     RowBox[{"s1", "*", "t"}], ")"}]}]}]}]], "Input",
