        RowBox[{"Floor", "[", 
         RowBox[{"Nc", "/", "2"}], "]"}]}], ";", "\n", 
       RowBox[{"Int", "=", 
        RowBox[{
         RowBox[{"c", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "-", " ", 
         RowBox[{"2", 
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"c", "[", 
              RowBox[{"[", 
               RowBox[{
                RowBox[{"2", " ", "k"}], " ", "+", "1"}], "]"}], "]"}], "/", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"4", " ", 
                RowBox[{"k", " ", "^", "2"}]}], " ", "-", "1"}], ")"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", "1", ",", "kf"}], "}"}]}], "]"}]}]}]}], ";", 
       "\n", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"b", "-", "a"}], ")"}], "*", 
        RowBox[{"Int", "/", "2"}]}]}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
