Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Period", "=", 
   RowBox[{"Table", "[", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Data", "[", 
       RowBox[{"[", "k", "]"}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "\[Omega]I"}], "*", 
