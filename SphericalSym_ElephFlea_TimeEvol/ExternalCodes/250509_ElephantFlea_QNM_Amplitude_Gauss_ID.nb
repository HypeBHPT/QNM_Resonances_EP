 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"DefiniteIntegral", "[", 
     RowBox[{"c_", ",", "a_", ",", "b_"}], "]"}], ":=", 
    RowBox[{"Module", "[", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"kf", ",", "nc", ",", "Nc", ",", " ", "Int"}], "}"}], ",", 
      "\n", 
      RowBox[{
       RowBox[{"nc", "=", 
        RowBox[{"Length", "@", "c"}]}], ";", "\n", 
       RowBox[{"Nc", "=", 
        RowBox[{"nc", "-", "1"}]}], ";", "\n", 
