    RowBox[{"Module", "[", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"nf", ",", " ", "Nf", ",", "c", ",", "x"}], "}"}], ",", "\n", 
      RowBox[{
       RowBox[{"nf", "=", 
